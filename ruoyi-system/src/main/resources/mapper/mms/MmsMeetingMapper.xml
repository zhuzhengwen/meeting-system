<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.MmsMeetingMapper">

    <resultMap type="com.ruoyi.system.domain.MmsMeeting" id="MmsMeetingResult">
        <result property="meetingId"   column="meeting_id"   />
        <result property="meetingNo"   column="meeting_no"   />
        <result property="title"       column="title"        />
        <result property="campus"      column="campus"       />
        <result property="roomId"      column="room_id"      />
        <result property="roomNumber"  column="room_number"  />
        <result property="category"    column="category"     />
        <result property="frequency"   column="frequency"    />
        <result property="meetingType" column="meeting_type" />
        <result property="tencentId"   column="tencent_id"   />
        <result property="startTime"   column="start_time"   />
        <result property="endTime"     column="end_time"     />
        <result property="hostUser"    column="host_user"    />
        <result property="hostName"    column="host_name"    />
        <result property="leadDept"    column="lead_dept"    />
        <result property="description" column="description"  />
        <result property="status"             column="status"              />
        <result property="processInstanceId"  column="process_instance_id" />
        <result property="createBy"           column="create_by"           />
        <result property="createTime"  column="create_time"  />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"  column="update_time"  />
        <result property="remark"      column="remark"       />
    </resultMap>

    <resultMap type="com.ruoyi.system.domain.MmsMeetingAttendee" id="AttendeeResult">
        <result property="attendeeId"   column="attendee_id"   />
        <result property="meetingId"    column="meeting_id"    />
        <result property="userId"       column="user_id"       />
        <result property="userName"     column="user_name"     />
        <result property="deptName"     column="dept_name"     />
        <result property="isDelegate"   column="is_delegate"   />
        <result property="delegateFrom" column="delegate_from" />
        <result property="delegateNote" column="delegate_note" />
    </resultMap>

    <sql id="selectMeetingVo">
        select meeting_id, meeting_no, title, campus, room_id, room_number, category,
               frequency, meeting_type, tencent_id, start_time, end_time,
               host_user, host_name, lead_dept, description, status,
               process_instance_id,
               create_by, create_time, update_by, update_time, remark
        from mms_meeting
    </sql>

    <!-- 实体条件查询，对应 BaseMapper.selectByCondition，支持 LIKE / 日期范围 -->
    <select id="selectByCondition" parameterType="com.ruoyi.system.domain.MmsMeeting" resultMap="MmsMeetingResult">
        <include refid="selectMeetingVo"/>
        <where>
            AND del_flag = '0'
            <if test="meetingNo != null and meetingNo != ''">
                AND meeting_no = #{meetingNo}
            </if>
            <if test="title != null and title != ''">
                AND title like concat('%', #{title}::text, '%')
            </if>
            <if test="campus != null and campus != ''">
                AND campus = #{campus}
            </if>
            <if test="category != null and category != ''">
                AND category = #{category}
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
            <if test="hostUser != null and hostUser != ''">
                AND host_user = #{hostUser}
            </if>
            <if test="leadDept != null and leadDept != ''">
                AND lead_dept like concat('%', #{leadDept}::text, '%')
            </if>
            <if test="beginDate != null and beginDate != ''">
                AND start_time &gt;= #{beginDate}::timestamp
            </if>
            <if test="endDate != null and endDate != ''">
                AND start_time &lt;= (#{endDate}::date + interval '1 day')
            </if>
        </where>
        order by start_time desc
    </select>

    <!-- ══════════════════════════════════════════════════════════════
         自定义方法
         ══════════════════════════════════════════════════════════════ -->

    <select id="selectMeetingsByDate" parameterType="String" resultMap="MmsMeetingResult">
        <include refid="selectMeetingVo"/>
        where DATE(start_time) = #{date}::date
          and del_flag = '0'
          and status != '1'
        order by campus, start_time
    </select>

    <!-- 参会人员 -->
    <select id="selectAttendeesByMeetingId" parameterType="Long" resultMap="AttendeeResult">
        select attendee_id, meeting_id, user_id, user_name, dept_name,
               is_delegate, delegate_from, delegate_note
        from mms_meeting_attendee
        where meeting_id = #{meetingId}
        order by attendee_id
    </select>

    <insert id="insertAttendee" parameterType="com.ruoyi.system.domain.MmsMeetingAttendee">
        insert into mms_meeting_attendee
            (meeting_id, user_id, user_name, dept_name, email, notify_email, is_delegate, delegate_from, delegate_note)
        values
            (#{meetingId}, #{userId}, #{userName}, #{deptName},
             #{email}, #{notifyEmail}, #{isDelegate}, #{delegateFrom}, #{delegateNote})
    </insert>

    <delete id="deleteAttendeesByMeetingId" parameterType="Long">
        delete from mms_meeting_attendee where meeting_id = #{meetingId}
    </delete>

    <update id="updateAttendeeDelegate" parameterType="com.ruoyi.system.domain.MmsMeetingAttendee">
        update mms_meeting_attendee
        set is_delegate = '1',
            delegate_from = #{delegateFrom},
            delegate_note = #{delegateNote},
            user_id   = #{userId},
            user_name = #{userName}
        where attendee_id = #{attendeeId}
    </update>

</mapper>
